<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#6A1B9A"
        android:orientation="horizontal"
        android:padding="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btBack"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Detalle del gasto"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- CONTENIDO -->
    <LinearLayout
        android:id="@+id/layoutContenido"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ICONO -->
        <ImageView
            android:id="@+id/imgCategoriaDetalle"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_marginBottom="20dp"/>

        <!-- CONCEPTO -->
        <TextView
            android:id="@+id/tvConceptoDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Concepto"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

        <!-- CANTIDAD -->

        <TextView
            android:id="@+id/tvCantidadDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.00 €"
            android:textSize="18sp"
            android:textColor="#D32F2F"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- FECHA -->
        <TextView
            android:id="@+id/tvFechaDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha: "
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <!-- CATEGORÍA -->
        <TextView
            android:id="@+id/tvCategoriaDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoría: "
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/tvDescripcionDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <!-- BOTONES -->
        <Button
            android:id="@+id/btnEditarGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar gasto"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#6A1B9A"
            android:textColor="#FFFFFF"/>
        <Button
            android:id="@+id/btnEliminarGasto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eliminar gasto"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>