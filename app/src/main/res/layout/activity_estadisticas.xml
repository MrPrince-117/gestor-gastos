<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6A1B9A"
        android:orientation="horizontal"
        android:padding="15dp">

        <ImageView
            android:id="@+id/btBack"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Estadísticas"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TOTAL -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total gastado"
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvTotalGastado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 €"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A"
                android:layout_marginBottom="24dp" />

            <!-- NÚMERO DE GASTOS -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número de gastos"
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvNumeroGastos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- GASTO MEDIO -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gasto medio"
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvGastoMedio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00 €"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- GASTOS POR CATEGORÍA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gastos por categoría"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>

            <TextView
                android:id="@+id/tvGastosPorCategoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="..."
                android:layout_marginTop="8dp"/>

        </LinearLayout>

    </ScrollView>


</LinearLayout>